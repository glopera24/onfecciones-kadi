# --- Envío de formulario de contacto (Resend) ---
# Crea una cuenta gratuita en https://resend.com y genera una API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Correo remitente verificado en Resend (dominio propio verificado)
CONTACT_FROM_EMAIL=contacto@confeccioneskadi.com

# Correo donde llegan los mensajes del formulario
CONTACT_TO_EMAIL=kadiconfecciones@gmail.com

# --- Alternativa: EmailJS (si prefieres envío 100% desde el cliente) ---
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=https://www.confeccioneskadi.com
